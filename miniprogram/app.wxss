page {
  background: #f6f7f9;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.button {
  height: 88rpx;
  border-radius: 10rpx;
  background: #1677ff;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.button.secondary {
  background: #eef4ff;
  color: #155bd4;
}

.button.disabled {
  opacity: 0.62;
}

.button.compact {
  width: 280rpx;
  height: 76rpx;
  margin: 0 auto;
  font-size: 26rpx;
}

.button.danger {
  background: #fff1f2;
  color: #dc2626;
  border: 1rpx solid #fecdd3;
  box-shadow: none;
  box-sizing: border-box;
}

.time-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 800;
}

.form-control,
.picker-value {
  width: 100%;
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f5f6f8;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.form-control {
  display: block;
}

input.form-control {
  height: 84rpx;
  line-height: 84rpx;
}

input.title-input {
  height: 96rpx;
  line-height: 96rpx;
}

textarea.form-control {
  height: 132rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  line-height: 84rpx;
}

.picker-value.has-arrow::after {
  content: "›";
  margin-left: 16rpx;
  color: #94a3b8;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.title-field {
  margin-bottom: 24rpx;
}

.title-input {
  min-height: 96rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.textarea-control {
  min-height: 132rpx;
  padding-top: 18rpx;
  padding-bottom: 18rpx;
  line-height: 1.45;
}

.empty {
  padding: 64rpx 24rpx;
  color: #6b7280;
  text-align: center;
}
