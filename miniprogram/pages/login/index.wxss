.login-page {
  padding-top: 120rpx;
}

.panel-title {
  margin-bottom: 18rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.account-item {
  position: relative;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef0f3;
}

.account-item:last-child {
  border-bottom: 0;
}

.account-item.active {
  background: #f7fbff;
}

.account-name {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.selected-tag {
  position: absolute;
  top: 20rpx;
  right: 0;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 10rpx;
  background: #e8f2ff;
  color: #155bd4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}
