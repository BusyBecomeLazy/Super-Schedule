<view class="page manage-page">
  <view class="profile-card section">
    <view class="profile-avatar">{{avatarInitial}}</view>
    <view class="profile-main">
      <view class="profile-name">{{profileName}}</view>
      <view class="profile-role">当前身份：{{roleText}}</view>
      <view class="profile-group">{{groupSummary}}</view>
    </view>
  </view>

  <view class="panel settings-panel">
    <view class="settings-cell" hover-class="settings-cell-press" hover-stay-time="80" bindtap="goGroups">
      <view class="settings-icon group-icon">群</view>
      <view class="settings-main">
        <view class="settings-title">群组管理</view>
        <view class="settings-desc">创建、加入、切换当前群组</view>
      </view>
      <view class="settings-arrow">›</view>
    </view>

    <view class="settings-cell" hover-class="settings-cell-press" hover-stay-time="80" bindtap="goMembers">
      <view class="settings-icon member-icon">员</view>
      <view class="settings-main">
        <view class="settings-title">成员权限设置</view>
        <view class="settings-desc">{{memberEntryDesc}}</view>
      </view>
      <view class="settings-arrow">›</view>
    </view>

    <view class="settings-cell" hover-class="settings-cell-press" hover-stay-time="80" bindtap="goDevOptions">
      <view class="settings-icon dev-icon">开</view>
      <view class="settings-main">
        <view class="settings-title">开发选项</view>
        <view class="settings-desc">切换开发账号等低频操作</view>
      </view>
      <view class="settings-arrow">›</view>
    </view>
  </view>

  <view wx:if="{{activeSheet}}" class="sheet-host">
    <view class="sheet-backdrop" catchtap="closeManageSheet"></view>
    <view class="bottom-sheet {{activeSheet === 'members' ? 'tall-sheet' : ''}} {{activeSheet === 'dev' ? 'compact-sheet' : ''}}">
      <view class="sheet-handle"></view>
      <view class="sheet-head">
        <view>
          <view class="sheet-title">{{sheetTitle}}</view>
          <view class="sheet-subtitle">{{sheetSubtitle}}</view>
        </view>
        <view class="sheet-close" hover-class="sheet-close-press" hover-stay-time="80" bindtap="closeManageSheet">×</view>
      </view>

      <scroll-view class="sheet-scroll" scroll-y enhanced>
        <view wx:if="{{activeSheet === 'groups'}}" class="sheet-content">
          <view class="manage-form">
            <view class="form-block">
              <view class="form-block-head">
                <view class="form-block-title">创建群组</view>
                <view class="hint">成员加入后默认是学员。</view>
              </view>
              <view class="field">
                <view class="label">新群组名称</view>
                <input class="form-control" placeholder-class="input-placeholder" placeholder="例如：产品研发组" value="{{groupName}}" bindinput="onGroupNameInput" />
              </view>
              <view class="button form-submit {{groupCreating ? 'disabled' : ''}}" hover-class="button-press" hover-stay-time="80" bindtap="createGroup">{{groupCreating ? '创建中...' : '创建群组'}}</view>
            </view>

            <view class="form-block">
              <view class="form-block-head">
                <view class="form-block-title">加入群组</view>
                <view class="hint">输入成员分享的邀请码。</view>
              </view>
              <view class="field">
                <view class="label">邀请码</view>
                <input class="form-control" placeholder-class="input-placeholder" placeholder="输入成员分享的邀请码" value="{{inviteCode}}" bindinput="onInviteCodeInput" />
              </view>
              <view class="button secondary form-submit {{groupJoining ? 'disabled' : ''}}" hover-class="button-press" hover-stay-time="80" bindtap="joinGroup">{{groupJoining ? '加入中...' : '加入群组'}}</view>
            </view>
          </view>

          <view class="sheet-section">
            <view class="section-title">当前群组</view>
            <view wx:if="{{groupsLoading}}" class="empty compact-empty">加载群组中...</view>
            <view wx:elif="{{groups.length === 0}}" class="empty compact-empty">暂无群组</view>
            <block wx:else>
              <view
                wx:for="{{groups}}"
                wx:key="id"
                class="cell group-cell {{currentGroupId === item.id ? 'active' : ''}}"
                hover-class="cell-press"
                hover-stay-time="80"
                bindtap="selectGroup"
                data-id="{{item.id}}"
              >
                <view class="cell-main">
                  <view class="cell-title">{{item.name}}</view>
                  <view class="cell-desc">邀请码：{{item.invite_code}}</view>
                </view>
                <view class="cell-actions">
                  <view
                    class="text-action"
                    hover-class="text-action-press"
                    hover-stay-time="80"
                    catchtap="copyInviteCode"
                    data-code="{{item.invite_code}}"
                  >复制</view>
                  <view wx:if="{{currentGroupId === item.id}}" class="state-tag">当前</view>
                </view>
              </view>
            </block>
          </view>
        </view>

        <view wx:elif="{{activeSheet === 'members'}}" class="sheet-content">
          <view wx:if="{{!currentGroupId}}" class="empty">请先创建或加入群组</view>
          <view wx:elif="{{membersLoading}}" class="empty">加载成员中...</view>
          <view wx:elif="{{!canManageMembers}}" class="empty">当前身份没有成员管理权限</view>
          <view wx:elif="{{members.length === 0}}" class="empty">暂无成员</view>
          <view wx:else>
            <view wx:for="{{members}}" wx:key="id" class="cell member-cell" hover-class="cell-press" hover-stay-time="80">
              <view class="member-avatar">{{item.avatarInitial}}</view>
              <view class="cell-main member-main">
                <view class="member-name-row">
                  <view class="cell-title">{{item.nickname}}</view>
                  <view wx:if="{{item.isSelf}}" class="self-tag">我</view>
                </view>
                <view class="cell-desc">用户 ID：{{item.user_id}}</view>
                <view class="role-desc">{{item.roleDesc}}</view>
              </view>
              <picker
                mode="selector"
                range="{{roleOptions}}"
                range-key="label"
                value="{{item.roleIndex}}"
                data-id="{{item.id}}"
                disabled="{{item.roleLocked || updatingMemberId === item.id}}"
                bindchange="onRoleChange"
              >
                <view class="role-chip select-chip {{item.roleLocked || updatingMemberId === item.id ? 'locked' : ''}}" hover-class="role-chip-press" hover-stay-time="80">{{updatingMemberId === item.id ? '更新中' : item.roleLabel}}</view>
              </picker>
            </view>
          </view>
        </view>

        <view wx:elif="{{activeSheet === 'dev'}}" class="sheet-content">
          <view class="dev-cell">
            <view>
              <view class="dev-title">切换开发账号</view>
              <view class="dev-desc">清除当前登录状态并回到登录页。</view>
            </view>
            <view class="button compact danger-action" hover-class="button-press" hover-stay-time="80" bindtap="switchDevAccount">切换</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
