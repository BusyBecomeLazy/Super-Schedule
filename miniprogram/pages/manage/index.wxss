.manage-page {
  padding-bottom: 132rpx;
}

.profile-card {
  min-height: 172rpx;
  padding: 30rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.profile-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 104rpx;
  background: #111827;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
}

.profile-main {
  min-width: 0;
  flex: 1;
}

.profile-name {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.profile-role {
  margin-top: 10rpx;
  color: #374151;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
}

.profile-group {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 23rpx;
  line-height: 1.35;
}

.settings-panel {
  padding: 0 24rpx;
}

.settings-cell {
  min-height: 116rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #eef0f3;
}

.settings-cell:last-child {
  border-bottom: 0;
}

.settings-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.group-icon {
  background: #10b981;
}

.member-icon {
  background: #1677ff;
}

.dev-icon {
  background: #64748b;
}

.settings-main {
  min-width: 0;
  flex: 1;
}

.settings-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.settings-desc {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 23rpx;
  line-height: 1.35;
}

.settings-arrow {
  color: #c4c9d2;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.sheet-host {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2147483647;
}

.sheet-backdrop {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 0;
  background: rgba(15, 23, 42, 0.28);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.bottom-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  height: 72vh;
  max-height: calc(100vh - 96rpx);
  padding: 12rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -24rpx 70rpx rgba(15, 23, 42, 0.2);
  box-sizing: border-box;
  animation: sheetUp 170ms ease-out;
  display: flex;
  flex-direction: column;
}

.bottom-sheet.tall-sheet {
  height: 78vh;
}

@keyframes sheetUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  background: #d1d5db;
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.sheet-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.2;
}

.sheet-subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.2;
}

.sheet-close {
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  line-height: 1;
}

.sheet-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.sheet-content {
  padding: 22rpx 0 8rpx;
}

.sheet-section {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #eef0f3;
}

.section-title {
  margin-bottom: 12rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.hint {
  margin-top: 4rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 1.5;
}

.manage-form {
  display: flex;
  flex-direction: column;
}

.manage-page .button {
  border-radius: 12rpx;
}

.form-block {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #eef0f3;
}

.form-block + .form-block {
  padding-top: 24rpx;
}

.form-block:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.form-block-head {
  margin-bottom: 18rpx;
}

.form-block-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.manage-page .form-control {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  background: #ffffff;
  color: #111827;
  font-weight: 600;
}

.input-placeholder {
  color: #c7cbd1;
  font-weight: 500;
}

.form-submit {
  margin-top: 18rpx;
}

.manage-page .button.secondary.form-submit {
  border: 1rpx solid #d6dbe3;
  background: #ffffff;
  color: #374151;
  box-sizing: border-box;
}

.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eef0f3;
}

.cell:last-child {
  border-bottom: 0;
}

.group-cell.active {
  margin: 0 -12rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.cell-main {
  min-width: 0;
  flex: 1;
}

.cell-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.cell-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.cell-desc {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 23rpx;
  line-height: 1.35;
}

.member-cell {
  align-items: center;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 26rpx;
  font-weight: 800;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.self-tag {
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #ecfdf5;
  color: #047857;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 800;
}

.role-desc {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
  line-height: 1.35;
}

.text-action,
.state-tag,
.role-chip {
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 23rpx;
  font-weight: 700;
}

.text-action {
  background: transparent;
  color: #475569;
  padding-left: 8rpx;
  padding-right: 8rpx;
}

.role-chip {
  min-width: 136rpx;
}

.role-chip.locked {
  color: #9ca3af;
}

.select-chip::after {
  content: "›";
  margin-left: 10rpx;
  color: #94a3b8;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.select-chip.locked::after {
  display: none;
}

.dev-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 10rpx 0;
}

.dev-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.dev-desc {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.4;
}

.danger-action {
  width: 132rpx;
  height: 64rpx;
  margin: 0;
  border: 1rpx solid #fecdd3;
  border-radius: 12rpx;
  background: #fff1f2;
  color: #dc2626;
  box-sizing: border-box;
  font-size: 24rpx;
}

.compact-empty {
  padding: 28rpx 0;
}
