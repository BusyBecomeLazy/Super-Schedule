<view class="page">
  <view class="section">
    <view class="title">课程表</view>
    <view class="subtitle">第 {{week}} 周</view>
  </view>

  <view wx:if="{{!currentGroupId}}" class="panel section">
    <view class="empty">请先到“群组”页创建或选择群组</view>
  </view>

  <view wx:elif="{{!hasSemester}}" class="panel section">
    <view class="empty">当前群组还没有学期</view>
    <view class="button" bindtap="createDefaultSemester">创建默认学期</view>
  </view>

  <block wx:else>
    <view class="section row-actions">
      <view class="button secondary" bindtap="refresh">刷新</view>
      <view class="button" bindtap="goCreateCourse">新增课程</view>
    </view>

    <view class="panel timetable">
      <view class="thead">
        <view></view>
        <view wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
      </view>
      <view wx:for="{{periods}}" wx:key="period_index" class="trow">
        <view class="period">{{item.period_index}}</view>
        <view wx:for="{{weekdays}}" wx:for-item="day" wx:for-index="dayIndex" wx:key="day" class="cell">
          <view wx:for="{{courses}}" wx:for-item="course" wx:key="id">
            <view wx:if="{{course.day_of_week === dayIndex + 1 && course.start_period === item.period_index}}" class="course">
              <view class="course-name">{{course.name}}</view>
              <view class="course-meta">{{course.location || ''}}</view>
              <view class="course-meta">{{course.start_period}}-{{course.end_period}}节</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>

