.row-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.timetable {
  overflow-x: auto;
}

.thead,
.trow {
  display: grid;
  grid-template-columns: 56rpx repeat(7, 1fr);
  min-width: 760rpx;
}

.thead view,
.period,
.cell {
  min-height: 76rpx;
  border-right: 1rpx solid #eef0f3;
  border-bottom: 1rpx solid #eef0f3;
  box-sizing: border-box;
  padding: 8rpx;
  font-size: 22rpx;
}

.thead view {
  color: #4b5563;
  font-weight: 700;
  text-align: center;
}

.period {
  color: #6b7280;
  text-align: center;
  font-weight: 600;
}

.cell {
  min-height: 96rpx;
}

.course {
  background: #e8f2ff;
  color: #155bd4;
  border-radius: 8rpx;
  padding: 8rpx;
  font-size: 22rpx;
  line-height: 1.3;
}

.course-name {
  font-weight: 700;
}

.course-meta {
  margin-top: 4rpx;
  color: #4473b9;
  font-size: 20rpx;
}

