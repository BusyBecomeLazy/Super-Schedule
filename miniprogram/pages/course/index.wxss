.course-page {
  min-height: 100vh;
  padding: 18rpx 0 132rpx;
  background: linear-gradient(180deg, #eef4ff 0%, #f7fafc 34%, #ffffff 100%);
  overflow-x: hidden;
}

.course-hero {
  position: relative;
  padding: 0 24rpx 10rpx;
  z-index: 10;
}

.round-action {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 6rpx 14rpx rgba(31, 41, 55, 0.05);
}

.round-action.subtle {
  color: #155bd4;
}

.round-action.primary {
  background: #1677ff;
  color: #ffffff;
  border-color: #1677ff;
  box-shadow: 0 10rpx 22rpx rgba(22, 119, 255, 0.18);
}

.round-action.primary.active {
  transform: rotate(45deg);
}

.week-control {
  margin-top: 4rpx;
  display: grid;
  grid-template-columns: 60rpx 1fr 132rpx;
  align-items: center;
  gap: 12rpx;
}

.action-cluster {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.action-menu {
  position: absolute;
  right: 24rpx;
  top: 76rpx;
  width: 286rpx;
  padding: 10rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.14);
  z-index: 30;
  transform-origin: 86% 0;
  animation: actionMenuIn 130ms ease-out;
}

.action-menu::before {
  content: "";
  position: absolute;
  top: -10rpx;
  right: 34rpx;
  width: 20rpx;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  border-left: 1rpx solid rgba(226, 232, 240, 0.95);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  transform: rotate(45deg);
}

.menu-item {
  min-height: 78rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
}

.menu-item + .menu-item {
  margin-top: 8rpx;
}

.menu-item.secondary {
  background: #eff6ff;
  color: #155bd4;
}

.menu-item.primary {
  background: #1677ff;
  color: #ffffff;
}

.menu-title {
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.2;
}

.menu-desc {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.15;
  opacity: 0.78;
}

@keyframes actionMenuIn {
  from {
    opacity: 0;
    transform: translateY(-8rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.week-nav {
  min-width: 0;
  height: 64rpx;
  padding: 0 8rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  display: grid;
  grid-template-columns: 52rpx 1fr 52rpx;
  align-items: center;
}

.arrow-button {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.week-info {
  min-width: 0;
  text-align: center;
}

.week-range {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.1;
}

.week-meta {
  margin-top: 4rpx;
  color: #64748b;
  font-size: 20rpx;
  line-height: 1.1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-state {
  margin: 24rpx;
  padding: 72rpx 32rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(31, 41, 55, 0.06);
}

.empty-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-text {
  margin: 14rpx 0 28rpx;
  color: #617084;
  font-size: 26rpx;
}

.row-actions {
  display: flex;
  gap: 14rpx;
}

.row-actions .button {
  flex: 1;
}

.row-actions.two {
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.nlp-textarea {
  height: 180rpx;
  min-height: 180rpx;
  font-weight: 600;
}

.parse-card {
  margin-top: 6rpx;
  padding: 22rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  box-shadow: 0 10rpx 24rpx rgba(21, 91, 212, 0.07);
}

.parse-title {
  margin-bottom: 16rpx;
  color: #155bd4;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.parse-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.parse-chip {
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 12rpx;
  background: #eef4ff;
  color: #155bd4;
  display: flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 800;
}

.draft-row {
  display: grid;
  grid-template-columns: 120rpx 1fr;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: #f5f6f8;
  font-size: 26rpx;
}

.draft-row + .draft-row {
  margin-top: 10rpx;
}

.draft-label {
  color: #6b7280;
  font-weight: 800;
}

.draft-value {
  color: #111827;
  font-weight: 800;
  line-height: 1.35;
  word-break: break-all;
}

.warning {
  margin: 12rpx 0 0;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: #fffbeb;
  color: #b45309;
  font-size: 24rpx;
  font-weight: 700;
}

.button.disabled {
  opacity: 0.62;
}

.missing-panel,
.risk-panel {
  margin: 12rpx 0;
  padding: 16rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.missing-panel {
  border: 1rpx solid #fed7aa;
  background: #fff7ed;
  color: #9a3412;
}

.missing-title {
  margin-bottom: 8rpx;
  font-weight: 900;
}

.missing-item {
  display: inline-flex;
  margin: 6rpx 8rpx 0 0;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  background: #ffedd5;
  color: #9a3412;
  font-size: 22rpx;
  font-weight: 800;
}

.risk-panel {
  border: 1rpx solid #fecaca;
  background: #fef2f2;
  color: #991b1b;
  font-weight: 700;
}

.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin: 18rpx 0 8rpx;
}

.candidate-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
}

.candidate-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 18rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 14rpx;
  background: #f8fbff;
}

.candidate-item.active {
  border-color: #1677ff;
  background: #eef6ff;
  box-shadow: 0 8rpx 18rpx rgba(22, 119, 255, 0.08);
}

.candidate-main {
  min-width: 0;
  flex: 1;
}

.candidate-name {
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
  word-break: break-all;
}

.candidate-meta {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.3;
  word-break: break-all;
}

.candidate-state {
  flex: none;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #155bd4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.timetable-scroll {
  width: 100%;
}

.timetable-shell {
  position: relative;
  width: 1080rpx;
  min-height: 400rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.68);
}

.week-header {
  display: grid;
  grid-template-columns: 82rpx repeat(7, 142rpx);
  height: 104rpx;
  background: rgba(255, 255, 255, 0.9);
  border-top: 1rpx solid rgba(238, 238, 238, 0.9);
  border-bottom: 1rpx solid rgba(238, 238, 238, 0.9);
}

.corner-cell,
.day-head {
  box-sizing: border-box;
}

.corner-cell {
  padding: 14rpx 8rpx;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
}

.month-label {
  line-height: 1.2;
}

.day-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #334155;
}

.day-head.today {
  background: rgba(237, 246, 255, 0.68);
  color: #155bd4;
}

.weekday {
  font-size: 28rpx;
  font-weight: 900;
}

.date-label {
  min-width: 76rpx;
  height: 36rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.day-head.today .date-label {
  background: #1677ff;
  color: #ffffff;
}

.grid-body {
  position: relative;
  display: grid;
  grid-template-columns: 82rpx repeat(7, 142rpx);
  grid-auto-flow: row;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(247, 250, 252, 0.88));
}

.period-cell,
.grid-cell {
  min-height: 108rpx;
  border-bottom: 1rpx solid rgba(238, 238, 238, 0.88);
  box-sizing: border-box;
}

.period-cell {
  padding: 14rpx 4rpx;
  color: #94a3b8;
  background: rgba(255, 255, 255, 0.86);
  text-align: center;
}

.period-index {
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.05;
}

.period-time {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 17rpx;
  line-height: 1;
}

.grid-cell {
  background: rgba(255, 255, 255, 0.45);
}

.course-card {
  z-index: 2;
  min-height: 0;
  justify-self: stretch;
  align-self: stretch;
  margin: 7rpx;
  padding: 12rpx 10rpx 10rpx;
  border-radius: 16rpx;
  color: #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  box-shadow: none !important;
  transition: transform 120ms ease-out, opacity 120ms ease-out, box-shadow 120ms ease-out;
}

.course-card-press {
  transform: translateY(2rpx) scale(0.985);
  opacity: 0.92;
}

.course-card.compact-card {
  padding: 9rpx 9rpx 8rpx;
}

.course-name {
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-line {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 20rpx;
  line-height: 1.18;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-foot {
  margin-top: auto;
  padding-top: 6rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 19rpx;
  font-weight: 800;
  line-height: 1.1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.compact-card .course-name {
  font-size: 22rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.compact-card .course-line {
  display: none;
}

.compact-card .course-foot {
  display: none;
}

.grid-empty {
  position: absolute;
  left: 82rpx;
  right: 0;
  top: 104rpx;
  height: 216rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a93a3;
  font-size: 28rpx;
  pointer-events: auto;
}

.grid-empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.sheet-host {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2147483647;
}

.sheet-backdrop {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 0;
  background: rgba(15, 23, 42, 0.28);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.bottom-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  height: 72vh;
  max-height: calc(100vh - 96rpx);
  padding: 12rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -24rpx 70rpx rgba(15, 23, 42, 0.2);
  box-sizing: border-box;
  animation: sheetUp 170ms ease-out;
  display: flex;
  flex-direction: column;
}

@keyframes sheetUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  background: #d1d5db;
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.sheet-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.2;
}

.sheet-subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.2;
}

.sheet-close {
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  line-height: 1;
}

.sheet-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.sheet-form {
  padding: 22rpx 0 6rpx;
}

.sheet-form .field {
  margin-bottom: 20rpx;
}

.sheet-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
}

.sheet-actions .button:first-child:last-child {
  grid-column: 1 / -1;
}

.detail-panel {
  padding: 24rpx 0;
}

.detail-row {
  display: grid;
  grid-template-columns: 110rpx 1fr;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.detail-label {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-value {
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
  word-break: break-all;
}
