.tabbar {
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(229, 231, 235, 0.9);
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -10rpx 28rpx rgba(15, 23, 42, 0.04);
}

.tabbar.hidden {
  display: none;
}

.tab-item {
  min-width: 132rpx;
  height: 96rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #8a94a6;
}

.tab-item::before {
  content: "";
  position: absolute;
  top: 4rpx;
  width: 34rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: transparent;
}

.tab-item.active {
  color: #1677ff;
}

.tab-item.active::before {
  background: #1677ff;
}

.tab-icon {
  position: relative;
  width: 52rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: inherit;
  transition: transform 120ms ease-out;
}

.tab-item.active .tab-icon {
  transform: translateY(-2rpx);
}

.tab-text {
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.1;
}

.tab-item.active .tab-text {
  font-weight: 900;
}

.tab-item.active .calendar-glyph,
.tab-item.active .book-glyph {
  border-width: 4rpx;
}

.tab-item.active .slider-line {
  height: 4rpx;
}

.tab-item.active .slider-dot {
  border-width: 4rpx;
}

.calendar-glyph {
  position: relative;
  width: 34rpx;
  height: 32rpx;
  border: 3rpx solid currentColor;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.calendar-ring {
  position: absolute;
  top: -7rpx;
  width: 4rpx;
  height: 10rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.calendar-ring.left {
  left: 7rpx;
}

.calendar-ring.right {
  right: 7rpx;
}

.calendar-line {
  position: absolute;
  left: 0;
  right: 0;
  top: 8rpx;
  height: 3rpx;
  background: currentColor;
  opacity: 0.55;
}

.calendar-dots {
  position: absolute;
  left: 6rpx;
  right: 6rpx;
  bottom: 5rpx;
  display: flex;
  justify-content: space-between;
}

.calendar-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: currentColor;
}

.book-glyph {
  position: relative;
  width: 35rpx;
  height: 32rpx;
  border: 3rpx solid currentColor;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.book-spine {
  position: absolute;
  left: 8rpx;
  top: 0;
  bottom: 0;
  width: 3rpx;
  background: currentColor;
  opacity: 0.5;
}

.book-line {
  position: absolute;
  left: 15rpx;
  right: 5rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: currentColor;
  opacity: 0.55;
}

.book-line.strong {
  top: 9rpx;
}

.book-line.weak {
  top: 17rpx;
}

.manage-glyph {
  position: relative;
  width: 34rpx;
  height: 30rpx;
}

.slider-line {
  position: absolute;
  left: 1rpx;
  right: 1rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: currentColor;
}

.slider-line.top {
  top: 6rpx;
}

.slider-line.middle {
  top: 14rpx;
}

.slider-line.bottom {
  top: 22rpx;
}

.slider-dot {
  position: absolute;
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 3rpx solid currentColor;
  box-sizing: border-box;
}

.slider-dot.first {
  top: 3rpx;
  left: 8rpx;
}

.slider-dot.second {
  top: 11rpx;
  right: 7rpx;
}
